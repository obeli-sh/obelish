// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CommandPalette snapshots > matches snapshot when closed 1`] = `<div />`;

exports[`CommandPalette snapshots > matches snapshot when open with commands 1`] = `
<div>
  <div
    data-testid="palette-backdrop"
    style="position: fixed; inset: 0; background-color: rgba(0, 0, 0, 0.62); display: flex; justify-content: center; align-items: flex-start; padding-top: 20vh; z-index: 1000;"
  >
    <div
      aria-label="Command palette"
      aria-modal="true"
      class="panel"
      role="dialog"
      style="width: 100%; max-width: 500px; background-color: var(--ui-panel-bg); border: 1px solid var(--ui-border); border-radius: var(--ui-radius); overflow: hidden; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);"
    >
      <div
        style="padding: 12px 16px; border-bottom: 1px solid var(--ui-border);"
      >
        <input
          placeholder="Type a command..."
          role="searchbox"
          style="width: 100%; padding: 8px 12px; background-color: var(--ui-panel-bg-alt); border: 1px solid var(--ui-border); border-radius: var(--ui-radius); color: var(--ui-text-primary); font-family: var(--ui-font-mono); font-size: 12px; letter-spacing: 0.06em; outline: none; box-sizing: border-box;"
          type="text"
          value=""
        />
      </div>
      <ul
        role="listbox"
        style="list-style: none; margin: 0px; padding: 0px; max-height: 300px; overflow-y: auto;"
      >
        <li
          aria-selected="true"
          role="option"
          style="padding: 8px 16px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background-color: color-mix(in srgb, var(--ui-accent) 12%, transparent); color: var(--ui-text-primary); border-left: 2px solid var(--ui-accent);"
        >
          <div>
            <div
              style="font-size: 12px; font-family: var(--ui-font-mono);"
            >
              Alpha Command
            </div>
            <div
              style="font-size: 12px; color: var(--ui-text-muted);"
            >
              Description for Alpha Command
            </div>
          </div>
        </li>
        <li
          aria-selected="false"
          role="option"
          style="padding: 8px 16px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background-color: transparent; color: var(--ui-text-primary); border-left: 2px solid transparent;"
        >
          <div>
            <div
              style="font-size: 12px; font-family: var(--ui-font-mono);"
            >
              Beta Command
            </div>
            <div
              style="font-size: 12px; color: var(--ui-text-muted);"
            >
              Description for Beta Command
            </div>
          </div>
        </li>
      </ul>
    </div>
  </div>
</div>
`;
